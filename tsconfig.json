{
	"compilerOptions": {
		"rootDir": "./src/js/",
		"outDir": "./dist/",
		"sourceMap": true,
		"strict": true,
		"exactOptionalPropertyTypes": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"useUnknownInCatchVariables": true,
		"module": "ESNext",
		"target": "ESNext",
		"allowJs": false,
		"lib": ["ESNext", "DOM"]
	}
}
